rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' ||
        request.auth.token.email == 'rihankhanrb1786@gmail.com'
      );
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config);
    }
    
    // Categories, Brands, Offers, Coupons, Settings, Suppliers, Stock, Delivery Slots
    match /categories/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /brands/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /offers/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /coupons/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /settings/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /suppliers/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /stock/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }
    match /delivery/{id} { allow read: if true; allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config); }

    // Users
    match /users/{userId} {
      allow read, write: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || !exists(/databases/$(database)/documents/settings/store-config);
      
      // Subcollections (cart, wishlist, addresses, notifications)
      match /cart/{itemId} {
        allow read, write: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || !exists(/databases/$(database)/documents/settings/store-config);
      }
      match /wishlist/{itemId} {
        allow read, write: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || !exists(/databases/$(database)/documents/settings/store-config);
      }
      match /addresses/{itemId} {
        allow read, write: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || !exists(/databases/$(database)/documents/settings/store-config);
      }
      match /notifications/{itemId} {
        allow read, write: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || !exists(/databases/$(database)/documents/settings/store-config);
      }
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || resource.data.deliveryBoyId == request.auth.uid);
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || !exists(/databases/$(database)/documents/settings/store-config);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid) || !exists(/databases/$(database)/documents/settings/store-config);
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() || !exists(/databases/$(database)/documents/settings/store-config);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid) || !exists(/databases/$(database)/documents/settings/store-config);
    }

    // Banners
    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/settings/store-config);
    }
  }
}
